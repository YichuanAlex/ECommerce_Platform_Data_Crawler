  <script>
    /**
     * listener FFSP ready.
     */
    function onFFSPReady() {
      const images = Array.from(document.images);

      if (images.length === 0) {
        window.dispatchEvent(new Event('ffsp-ready'));
        return;
      }

      let loadedCount = 0;
      function checkDone() {
        loadedCount++;
        if (loadedCount === images.length) {
          window.dispatchEvent(new Event('ffsp-ready'));
        }
      }

      images.forEach(img => {
        if (img.complete && img.naturalWidth !== 0) {
          checkDone();
        } else {
          img.addEventListener('load', checkDone, { once: true });
          img.addEventListener('error', checkDone, { once: true });
        }
      });
    }

    function fccDomClick(e) {
      e.stopPropagation();
      const { fccScheme, url } = e.currentTarget.dataset;
      const _url = fccScheme || url;
      console.log('<<<<<< fccDomClick', _url);
      if (_url) {
        try {
          window.__megability_bridge__.asyncCall(
            'navigator',
            'openURL',
            {
              url: _url,
            }
          )
        } catch {
          window.location.href = _url;
        }
      }
    }

    function bindFccClick(root) {
      Array.from(root.querySelectorAll('[data-fcc-scheme]')).forEach(ele => {
        ele.setAttribute('data-track-homeSnapshot', '1');
        ele.addEventListener('click', fccDomClick);
      });
    }

    /**
   * ID for the snapshot placeholder element
   */
    const PLACEHOLDER_ID = 'fcc-snapshot-placeholder';
    /**
     * Initialize snapshot placeholder and set snapshot content
     * @param cacheKey - Cache key used to retrieve snapshot content from localStorage
     */
    function paintSnapshot(cacheKey) {
      // Init snapshot placeholder element.
      let fccSnapshotPlaceholder = document.getElementById(PLACEHOLDER_ID);
      if (!fccSnapshotPlaceholder) {
        const newPlaceholder = document.createElement('div');
        newPlaceholder.id = PLACEHOLDER_ID;
        newPlaceholder.style.position = 'absolute';
        newPlaceholder.style.width = '100%';
        newPlaceholder.style.top = '0';
        newPlaceholder.style.left = '0';
        newPlaceholder.style.zIndex = '9999';
        document.body.appendChild(newPlaceholder);
        fccSnapshotPlaceholder = newPlaceholder;
      }

      window.__fly__ = window.__fly__ || {};

      // Get snapshot from cache and paint.
      const snapshotCache = localStorage.getItem(cacheKey);
      if (fccSnapshotPlaceholder && snapshotCache && (!window.__fly__.fccHit)) {
        fccSnapshotPlaceholder.innerHTML = snapshotCache;
        bindFccClick(fccSnapshotPlaceholder);
        window.__fly__.fccHit = true;
        onFFSPReady();
        window.bodySnapshot = true;
      }
    }

    function queryString() {
      const res = {};
      const target = window.location.search + window.location.hash.replace(/^#!/, '#');
      target.replace(/([^=?#&]*)=([^?#&]*)/g, function (e, $1, $2) {
        res[$1] = $2;
      });
      return res;
    }

    const query = queryString() || {};
    if (query.hideWebSnapshot !== '1') {
      let keyName = 'fcc-cache-11.22.69-' + location.pathname;
      if (!window.isTab) {
        keyName += '-notInTab';
        if (query.iconBizType) {
          keyName += '-' + query.iconBizType;
        }
      }
      paintSnapshot(keyName);
      window.__HIDE_WEB_SNAPSHOT__ = false;
    } else {
      window.__HIDE_WEB_SNAPSHOT__ = true;
    }

  </script>
